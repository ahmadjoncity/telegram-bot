# ============================================================
#  Ustoz AKA AI Bot - sozlamalar shabloni
#  Bu faylni nusxalab ".env" deb nomlang va qiymatlarni to'ldiring.
#  ESLATMA: ".env" faylini HECH QACHON GitHub'ga yuklamang!
# ============================================================

# --- Telegram (majburiy) ---
# @BotFather dan olinadi
TELEGRAM_TOKEN=
# Sizning Telegram ID raqamingiz (@userinfobot dan oling)
ADMIN_ID=

# --- AI providerlar ---
# Bepul: https://console.groq.com  (chat, vision, ovoz uchun majburiy)
GROQ_API_KEY=
# Bepul tier: https://dashboard.cohere.com  (ixtiyoriy, qo'shimcha model)
COHERE_API_KEY=

# --- Rasm generatsiya (Pollinations) ---
# Ishonchli va tez rasm uchun BEPUL kalit oling: https://enter.pollinations.ai
# Kalitsiz ham ishlaydi, lekin limit qattiq (ba'zan ishlamasligi mumkin).
POLLINATIONS_TOKEN=
IMAGE_MODEL=flux
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024

# --- Obuna talab qilinadigan ijtimoiy tarmoqlar ---
REQUIRED_CHANNEL=@ustozaka_ai
CHANNEL_URL=https://t.me/ustozaka_ai
INSTAGRAM_URL=https://instagram.com/ustozainews

# --- Tarif / limitlar (ixtiyoriy, standart qiymatlar bor) ---
FREE_DAYS=20
PREMIUM_SOM=15000
PREMIUM_MONTHS=1
STARS_PRICE=50
FREE_IMAGE_PER_DAY=5
REFERRAL_BONUS_DAYS=7

# --- To'lov: karta orqali (chek bilan) ---
CARD_NUMBER=8600 1234 5678 9012
CARD_HOLDER=USTOZ AKA

# --- To'lov tizimlari (ixtiyoriy) ---
PAYME_MERCHANT_ID=
CLICK_MERCHANT_ID=

# --- Boshqa (ixtiyoriy) ---
DB_FILE=db.json
