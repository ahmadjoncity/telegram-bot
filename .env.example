# ============================================================
#  Ustoz AKA AI Bot - sozlamalar shabloni
#  Bu faylni nusxalab ".env" deb nomlang va qiymatlarni to'ldiring.
#  ESLATMA: ".env" faylini HECH QACHON GitHub'ga yuklamang!
# ============================================================

# --- Telegram (MAJBURIY) ---
# @BotFather dan olinadi
TELEGRAM_TOKEN=

# --- AI providerlar (kamida BITTASI majburiy) ---
# Bepul: https://console.groq.com
GROQ_API_KEY=
# Bepul tier: https://dashboard.cohere.com
COHERE_API_KEY=

# --- Admin (MAJBURIY) ---
# Sizning Telegram ID raqamingiz (@userinfobot dan oling)
ADMIN_ID=

# --- Obuna talab qilinadigan kanal ---
# @ belgisi bilan yozing. Bot o'sha kanalda ADMIN bo'lishi shart!
REQUIRED_CHANNEL=@ustozaka_ai

# --- Instagram (ixtiyoriy) ---
INSTAGRAM_URL=https://instagram.com/ustozainews

# --- Imtihon test linki (ixtiyoriy) ---
EXAM_URL=https://htmlpreview.github.io/?https://github.com/ahmadjoncity/alxorazmiytayyorlov/blob/main/index.html

# --- Premium narxi va bepul muddat ---
FREE_DAYS=20
PREMIUM_SOM=15000
PREMIUM_STARS=50

# --- To'lov tizimlari (ixtiyoriy) ---
PAYME_MERCHANT_ID=
CLICK_MERCHANT_ID=

# --- Ma'lumotlar bazasi fayli ---
# Railway/Render da fayl tizimi VAQTINCHALIK! Volume ulab, bu yerga uning yo'lini yozing,
# aks holda har deploy/restart'da barcha foydalanuvchilar va Premium yo'qoladi.
# Masalan Railway Volume /data ga ulansa:
# DB_FILE=/data/db.json
DB_FILE=
